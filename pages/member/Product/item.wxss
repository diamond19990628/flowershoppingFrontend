/* 全局页面背景，让卡片更醒目 */
page {
  background-color: #f7f7f7;
  padding: 30rpx 0; /* 模拟卡片浮动 */
}

/* --- 核心卡片容器 --- */
.pdp-card-container {
  width: 690rpx; /* 375*2 - 间距 */
  background-color: #ffffff;
  border-radius: 40rpx; /* 大圆角 */
  margin: 0 auto;
  overflow: hidden; /* 确保内容不超出圆角 */
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.08); /* 立体投影 */
  padding-bottom: 40rpx; /* 底部留白 */
}

/* --- 1. 图片轮播区域 --- */
.pdp-image-wrapper {
  position: relative;
  width: 100%;
  height: 600rpx; /* 根据设计调整高度 */
  background-color: #e0e0e0; /* 占位色 */
  border-radius: 40rpx 40rpx 0 0;
}

.pdp-main-image {
  width: 100%;
  height: 100%;
  border-radius: 40rpx 40rpx 0 0;
}

/* 返回按钮 */
.back-btn {
  position: absolute;
  top: 30rpx;
  left: 30rpx;
  width: 72rpx;
  height: 72rpx;
  background-color: rgba(255, 255, 255, 0.7); /* 半透明白 */
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  transition: all 0.2s;
}

.back-icon {
  font-size: 32rpx;
  color: #666;
  margin-right: 4rpx; /* 微调箭头位置 */
}

/* 返回按钮点击反馈 */
.back-btn-hover {
  background-color: rgba(255, 255, 255, 0.9);
  transform: scale(0.95);
}

/* --- 2. 信息区域 --- */
.pdp-info-section {
  padding: 40rpx 40rpx 20rpx;
}

.pdp-name {
  font-size: 36rpx;
  font-weight: 500;
  color: #8c7340; /* 优雅的金色/深橄榄色 */
  margin-bottom: 24rpx;
}

.pdp-price-wrapper {
  display: flex;
  align-items: baseline;
}

.pdp-currency {
  font-size: 32rpx;
  font-weight: bold;
  color: #8c7340;
  margin-right: 8rpx;
}

/* --- 3. 提示区域 --- */
.pdp-tips-section {
  padding: 0 40rpx;
  font-size: 24rpx;
  color: #a0a0a0; /* 柔和的灰色 */
  line-height: 1.6;
  margin-bottom: 50rpx;
}

/* --- 4. 底部按钮 --- */
.pdp-action-footer {
  padding: 0 40rpx;
}

.btn-add-cart {
  width: 100% !important; /* 强制覆盖原生 button 宽度 */
  height: 100rpx;
  background-color: #8c7340; /* 品牌主色 */
  color: #ffffff;
  border-radius: 50rpx; /* 全圆角胶囊 */
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 10rpx 30rpx rgba(140, 115, 64, 0.3); /* 带有色调的阴影，显高级 */
}

/* 按钮点击特效 */
.btn-hover-effect {
  opacity: 0.85;
  transform: translateY(2rpx); /* 点击时轻微下沉 */
  box-shadow: 0 6rpx 20rpx rgba(140, 115, 64, 0.2);
}