.ts-about-container {
  background-color: #f9f9f9;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 顶部图片区域 */
.ts-swiper-section {
  background-color: #fff;
  padding-bottom: 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  height: 600rpx;
}

.ts-swiper-section image {
  width: 100%;
  height: 450rpx;
}
.ts-swiper-section-font {
  font-size: 32rpx;
  color: #77662E;
  margin-top: 20rpx;
}
.ts-dots-row {
  display: flex;
  justify-content: center;
  margin: 20rpx 0;
}

.ts-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #ddd;
  border-radius: 50%;
  margin: 0 8rpx;
}

.ts-dot.active {
  background-color: #71602e;
}

.ts-location-tip {
  font-size: 26rpx;
  color: #71602e;
}

/* 地址卡片 */
.ts-address-card {
  padding: 40rpx 30rpx;
  text-align: center;
}

.ts-address-title {
  font-size: 32rpx;
  color: #71602e;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.ts-address-sub {
  font-size: 30rpx;
  color: #71602e;
  margin-bottom: 30rpx;
}

.ts-nav-btn {
  display: inline-block;
  padding: 15rpx 60rpx;
  background-color: #fffaf5;
  color: #71602e;
  font-size: 26rpx;
  border-radius: 15rpx;
  border: 1px solid #e0e0e0;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
}

/* 详细列表 */
.ts-detail-info {
  padding: 20rpx 40rpx;
}

.ts-info-item {
  display: flex;
  margin-bottom: 30rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.ts-flex-start {
  align-items: flex-start;
}

.ts-label {
  color: #333;
  width: 200rpx;
  flex-shrink: 0;
}

.ts-value {
  color: #71602e;
}

.ts-qrcode-box {
  width: 200rpx;
  height: 200rpx;
  border: 1px solid #eee;
  padding: 10rpx;
  background: #fff;
}

.ts-qrcode {
  width: 100%;
  height: 100%;
}
