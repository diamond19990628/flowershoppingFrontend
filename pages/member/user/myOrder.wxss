/* ==============================
   全局与基础样式
   ============================== */
   page {
    background-color: #fff;
    font-family: "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  }
  
  /* 顶部装饰线 */
  .top-bar {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding: 20rpx 30rpx;
    border-bottom: 1rpx dashed #A38E58;
    margin-bottom: 10rpx;
  }
  
  .slogan {
    font-size: 24rpx;
    color: #A38E58;
  }
  
  .brand {
    font-size: 34rpx;
    color: #5C4A33;
    font-weight: 500;
  }
  
  /* 标题栏 */
  .header {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100rpx;
    position: relative;
  }
  
  .back-btn {
    position: absolute;
    left: 40rpx;
  }
  
  .arrow-left {
    width: 20rpx;
    height: 20rpx;
    border-left: 4rpx solid #5C4A33;
    border-bottom: 4rpx solid #5C4A33;
    transform: rotate(45deg);
  }
  
  .title {
    font-size: 34rpx;
    color: #5C4A33;
    font-weight: 600;
  }
  
  /* 搜索框 */
  .search-container {
    padding: 20rpx 40rpx;
  }
  
  .search-box {
    background-color: #F3F4F6;
    height: 72rpx;
    border-radius: 20rpx;
    display: flex;
    align-items: center;
    padding: 0 30rpx;
  }
  
  .search-placeholder {
    color: #B2B2B2;
    font-size: 26rpx;
    margin-left: 10rpx;
  }
  
  /* ==============================
     Tabs 切换
     ============================== */
  .tabs {
    display: flex;
    padding: 0 40rpx;
    margin-top: 20rpx;
  }
  
  .tab {
    flex: 1;
    text-align: center;
    font-size: 28rpx;
    color: #334155;
    padding-bottom: 20rpx;
    position: relative;
  }
  
  .tab.active {
    font-weight: bold;
  }
  
  .tab.active .line {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 140rpx;
    height: 6rpx;
    background-color: #A38E58;
    border-radius: 3rpx;
  }
  
  /* ==============================
     订单卡片区域
     ============================== */
  .order-list {
    padding: 20rpx 40rpx; /* 调整了左右留白，防止卡片过挤 */
  }
  
  /* 卡片整体：补回了浅棕色边框和圆角 */
  .order-card {
    background: #fff;
    border: 2rpx solid #E2DCC8; /* 👈 补上了精细的浅棕色边框 */
    border-radius: 36rpx;     /* 👈 还原了大圆角式样 */
    padding: 30rpx;
    box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.06); /* 底部轻微阴影 */
    margin-bottom: 30rpx;
  }
  
  /* 顶部单号行 */
  .card-header-top {
    display: flex;
    justify-content: space-between;
    margin-bottom: 20rpx;
    font-size: 26rpx;
  }
  .order-no { color: #999; }
  .order-status { color: #333; font-weight: bold; }
  
  /* 商品浅色包裹区 */
  .product-section {
    background-color: #F8F9FB;
    border-radius: 16rpx;
    padding: 20rpx;
    margin-bottom: 20rpx;
  }
  .product-main {
    display: flex;
  }
  .product-img {
    width: 140rpx;
    height: 140rpx;
    border-radius: 12rpx;
    background-color: #eee;
  }
  .product-info {
    flex: 1;
    margin-left: 20rpx;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  
  /* 商品名与单价行 */
  .info-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }
  .name { font-size: 30rpx; color: #333; font-weight: bold; }
  .price-red { color: #FF4D4F; font-size: 28rpx; font-weight: bold; }
  .quantity { color: #999; font-size: 24rpx; margin-left: 10rpx; }
  
  /* 内部虚线分割 */
  .info-split-line {
    border-top: 1rpx dashed #E0E0E0;
    margin: 15rpx 0;
  }
  
  /* 合计行 */
  .info-bottom {
    text-align: right;
    font-size: 26rpx;
  }
  .total-label { color: #666; }
  .total-price { font-size: 32rpx; color: #333; font-weight: bold; }
  
  /* ==============================
     收货信息与时间
     ============================== */
  .address-section {
    background-color: #F8F9FB;
    border-radius: 16rpx;
    padding: 20rpx;
    font-size: 28rpx;
    color: #333;
  }
  .user-info {
    margin-bottom: 10rpx;
  }
  .user-name { font-weight: bold; margin-right: 20rpx; }
  .user-phone { color: #666; }
  .address-detail {
    color: #666;
    font-size: 26rpx;
    line-height: 1.5;
  }
  .delivery-time {
    margin-top: 15rpx;
    padding-top: 15rpx;
    border-top: 1rpx solid #EFEFEF;
    font-size: 24rpx;
    color: #A38E58; /* 强调品牌的金棕色 */
  }
  
  /* ==============================
     底部按钮
     ============================== */
  .card-footer {
    margin-top: 30rpx;
    display: flex;
    justify-content: center;
  }
  .btn-confirm {
    background-color: #A38E58;
    color: #fff;
    width: 240rpx !important; /* 修正了打架的宽度，使其精致居中 */
    height: 70rpx;
    line-height: 70rpx;
    font-size: 26rpx;
    border-radius: 35rpx;
    padding: 0;
    font-weight: normal;
  }
  .btn-confirm::after {
    border: none;
  }

  /* ==============================
   微信二维码弹窗样式
   ============================== */
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6); /* 半透明遮罩 */
  backdrop-filter: blur(8rpx);   /* 毛玻璃效果，提升高级感 */
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.dialog-container {
  width: 560rpx;
  background: #fff;
  border-radius: 40rpx;
  position: relative;
  padding: 60rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  border: 2rpx solid #E2DCC8; /* 与订单卡片一致的边框 */
  animation: fadeInScale 0.3s ease-out; /* 弹出动画 */
}

/* 关闭按钮 */
.dialog-close {
  position: absolute;
  top: 20rpx;
  right: 30rpx;
  font-size: 50rpx;
  color: #B2B2B2;
  font-weight: 300;
  line-height: 1;
  padding: 10rpx;
}

.dialog-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dialog-title {
  font-size: 36rpx;
  color: #5C4A33;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.dialog-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 40rpx;
}

/* 二维码容器 */
.qr-code-wrapper {
  width: 400rpx;
  height: 400rpx;
  background-color: #F8F9FB; /* 浅灰色占位 */
  border: 1rpx solid #EEE;
  border-radius: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

.qr-img {
  width: 100%;
  height: 100%;
}

.qr-placeholder {
  color: #CCC;
  font-size: 28rpx;
}

.dialog-footer {
  margin-top: 40rpx;
  font-size: 26rpx;
  color: #A38E58; /* 品牌色 */
  background: #FDF9F0;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
}

/* 进场动画 */
@keyframes fadeInScale {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}
.pay-loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.38);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.pay-loading-dialog {
  width: 470rpx;
  padding: 48rpx 36rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.98);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.12);
}

.spinner-wrapper {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.spinner-ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 8rpx solid rgba(212, 175, 55, 0.18);
  border-top: 8rpx solid #d4af37;
  animation: payRotate 0.9s linear infinite;
  box-sizing: border-box;
}

.spinner-core {
  position: absolute;
  font-size: 38rpx;
  font-weight: 600;
  color: #d4af37;
  line-height: 1;
}

.pay-loading-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.pay-loading-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
  text-align: center;
}

@keyframes payRotate {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.4);
  z-index: 999;

  display: flex;
  align-items: center;
  justify-content: center;
}

.dialog-box {
  width: 520rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
}

.dialog-content {
  text-align: center;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 40rpx;
}

.dialog-actions {
  display: flex;
  justify-content: space-between;
}

.dialog-btn {
  width: 48%;
  height: 72rpx;
  border-radius: 36rpx;

  display: flex;
  align-items: center;
  justify-content: center;

  font-size: 28rpx;
}

/* 取消按钮（灰色） */
.dialog-btn.cancel {
  background: #f2f2f2;
  color: #666;
}

/* 确认按钮（你这个金色体系） */
.dialog-btn.confirm {
  background: #7a6e39;
  color: #fff;
}