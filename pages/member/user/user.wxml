<view class="ts-login-page">
  <view class="ts-header-slogan">
    <text class="ts-slogan-left">在最美的时光遇见你 🌷</text>
    <text class="ts-slogan-right">汀山花语</text>
  </view>
  <view class="ts-header-line"></view>

  <view class="ts-main-content">
    <image class="ts-illustration {{isLogined ? 'is-logined-img' : ''}}" src="../../img/welcome.png" mode="widthFix"></image>
    <view class="ts-flower-image"><image src="../../img/flower_water.png"/></view>
    
    <view class="ts-login-card {{isLogined ? 'ts-logged-card' : ''}}">
      <block wx:if="{{!isLogined}}">
        <view class="ts-welcome-msg">欢迎您的加入！</view>
        <button class="ts-login-btn" bind:tap="onLogin">登陆/注册</button>
      </block>

      <block wx:else>
        <view class="ts-logged-user">
          <view class="ts-user-avatar">
            <image src="{{userInfo.avatarUrl || '../../img/default_avatar.png'}}" mode="aspectFill"></image>
          </view>
          <text class="ts-user-name">{{nickName}}</text>
        </view>
      </block>
    </view>

    <view class="ts-logged-menu" wx:if="{{isLogined}}">
      <view class="ts-menu-item" bindtap="toOrder">我的订单</view>
      <view class="ts-menu-item" bindtap="toAddress">收货地址</view>
      <view class="ts-menu-item" bindtap="toContact">联系商家</view>
      <view class="ts-menu-item" bind:tap="toAdmin" wx:if="{{isAdmin==1}}">前往管理员界面</view>
    </view>
  </view>

  <common-footer index="5" url="/pages/member/user/user"/>
</view>
<view class="ts-dialog-mask {{showdialog ?'':'hiddendialog'}}">
  <view class="ts-dialog-container">
    <view class="ts-dialog-avatar-box">
      <view class="ts-dialog-avatar-circle">
        <text class="ts-dialog-avatar-icon">👤</text>
        <view class="ts-dialog-edit-icon">✎</view>
      </view>
    </view>

    <view class="ts-dialog-header">
      <view class="ts-dialog-title">欢迎加入汀山花语</view>
      <view class="ts-dialog-subtitle">请完善个人信息完成注册</view>
    </view>

    <view class="ts-dialog-form">
      <view class="ts-form-item">
        <text class="ts-label">昵称<text class="ts-required">*</text></text>
        <input data-field="nickName" bindinput="onInput" type="nickname" class="ts-input" placeholder="请输入昵称" placeholder-class="ts-placeholder" />
      </view>
    </view>

    <view class="ts-dialog-footer">
      <button class="ts-submit-btn" bind:tap="onNewUserLogin">快速注册</button>
      <view class="ts-skip-btn">暂时跳过</view>
    </view>
  </view>
</view>
<errorDialog isErrorVisible="{{isErrorVisible}}" errorMessage="{{errorMessage}}"/>
<view class="ts-loading-mask {{isLoading ? '' : 'hiddendialog'}}">
  <view class="ts-loading-container">
    <view class="ts-loading-spinner"></view>
    
    <view class="ts-loading-text">
      <text class="ts-loading-title">正在验证身份</text>
      <text class="ts-loading-subtitle">请稍候，开启您的精彩之旅</text>
    </view>
    
    <view class="ts-loading-line"></view>
  </view>
</view>
<view wx:if="{{tsRegisterVisible}}" class="ts-reg-mask" bindtap="onCloseRegisterDialog">
  <view class="ts-reg-sheet" catchtap="noop">

    <view class="ts-reg-handle"></view>

    <view class="ts-reg-header">
      <view>
        <view class="ts-reg-title">完善注册信息</view>
        <view class="ts-reg-subtitle">用于订单联系与配送确认</view>
      </view>
      <view class="ts-reg-close" bindtap="onCloseRegisterDialog">×</view>
    </view>

    <view class="ts-reg-form">
      <view class="ts-reg-field">
        <view class="ts-reg-label">姓名</view>
        <input data-field="nickName" bindinput="onInput" type="nickname" class="ts-input" placeholder="请输入昵称" placeholder-class="ts-placeholder" />
      </view>

      <view class="ts-reg-field">
        <view class="ts-reg-label">手机号</view>

        <button
          class="ts-reg-phone-btn"
          open-type="getPhoneNumber"
          bindgetphonenumber="onGetPhoneNumber"
        >
          <text wx:if="{{!phoneNumber}}">微信授权获取手机号</text>
          <text wx:else>{{phoneNumber}}</text>
        </button>

        <view class="ts-reg-tip">
          需用户主动点击授权，手机号将用于订单通知
        </view>
      </view>
    </view>

    <button
      class="ts-reg-submit"
      loading="{{registerSubmitting}}"
      disabled="{{registerSubmitting}}"
      bindtap="onSubmitRegister"
    >
      完成注册
    </button>

    <view class="ts-reg-safe-bottom"></view>
  </view>
</view>