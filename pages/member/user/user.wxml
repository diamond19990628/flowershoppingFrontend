<view class="ts-login-page">
  <view class="ts-header-slogan">
    <text class="ts-slogan-left">在最美的时光遇见你 🌷</text>
    <text class="ts-slogan-right">汀山花语</text>
  </view>
  <view class="ts-header-line"></view>

  <view class="ts-main-content">
    <image class="ts-illustration" src="../../img/welcome.png" mode="widthFix"></image>
    <view class="ts-flower-image"><image src="../../img/flower_water.png"/></view>
    <view class="ts-login-card">
      
      <view class="ts-welcome-msg">欢迎您的加入！</view>
      <button class="ts-login-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">登陆/注册</button>
    </view>
  </view>

  <common-footer index="5" url="/pages/member/user/user"/>
</view>
<view class="ts-dialog-mask {{showdialog ?'':'hiddendialog'}}">
  <view class="ts-dialog-container">
    <view class="ts-dialog-avatar-box">
      <view class="ts-dialog-avatar-circle">
        <text class="ts-dialog-avatar-icon">👤</text>
        <view class="ts-dialog-edit-icon">✎</view>
      </view>
    </view>

    <view class="ts-dialog-header">
      <view class="ts-dialog-title">欢迎加入汀山花语</view>
      <view class="ts-dialog-subtitle">请完善个人信息完成注册</view>
    </view>

    <view class="ts-dialog-form">
      <view class="ts-form-item">
        <text class="ts-label">昵称<text class="ts-required">*</text></text>
        <input data-field="nickName" bindinput="onInput" type="nickname" class="ts-input" placeholder="请输入昵称" placeholder-class="ts-placeholder" />
      </view>
    </view>

    <view class="ts-dialog-footer">
      <button class="ts-submit-btn" bind:tap="login">快速注册</button>
      <view class="ts-skip-btn">暂时跳过</view>
    </view>
  </view>
</view>
<errorDialog isErrorVisible="{{isErrorVisible}}" errorMessage="{{errorMessage}}"/>