.ts-login-page {
  min-height: 100vh;
  background-color: #ffffff;
  display: flex;
  flex-direction: column;
  padding: 0 30rpx;
  box-sizing: border-box;
}

/* 顶部标语样式 */
.ts-header-slogan {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding-top: 60rpx;
  padding-bottom: 10rpx;
}

.ts-slogan-left {
  font-size: 24rpx;
  color: #71602e;
}

.ts-slogan-right {
  font-size: 38rpx;
  font-weight: bold;
  color: #71602e;
  letter-spacing: 2rpx;
}

.ts-header-line {
  width: 100%;
  height: 1rpx;
  border-bottom: 1px dashed #71602e; /* 还原图中的虚线分割 */
  margin-bottom: 40rpx;
}

/* 插画与卡片布局 */
.ts-main-content {
  position: relative;
  width: 100%;
  margin-top: 50rpx;
  display: flex;
  justify-content: center;
}

.ts-illustration {
  width: 90%;
  opacity: 0.9;
  margin-top: 250rpx;
}
.ts-flower-image{
  position: absolute;
  width: 184rpx;
  height: 184rpx;
  top: 0px;
  margin-left:450rpx;
}
.ts-flower-image image{
  width: 100%;
  height: 100%;
}
/* 悬浮登录卡片 */
.ts-login-card {
  position: absolute;
  top: 15%; /* 根据插画位置微调 */
  width: 80%;
  background-color: #71602e;
  border-radius: 40rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.3); /* 还原图中较重的阴影 */
  z-index: 10;
  top: 150rpx;
}

.ts-welcome-msg {
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  margin-bottom: 20rpx;
  text-align: left;
}

.ts-login-btn {
  font-size: 40rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
  background-color: #71602e;
  color: #fff;
}

/* 底部 TabBar */
.ts-tabbar-box {
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
  height: 120rpx;
  background: #ffffff;
  border-radius: 60rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 4rpx 30rpx rgba(0, 0, 0, 0.1);
  border: 1px solid #eee;
}

.ts-tab-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.ts-iconfont {
  font-size: 44rpx;
  color: #999;
}

/* 选中状态：顶部半圆修饰 */
.ts-tab-item.ts-active .ts-iconfont {
  color: #71602e;
}

.ts-active-circle {
  position: absolute;
  width: 100rpx;
  height: 50rpx;
  background-color: #71602e;
  border-radius: 0 0 50rpx 50rpx; /* 向上突出的半圆 */
}

/* 在半圆中心加个小点，对应图中设计 */
.ts-active-circle::after {
  content: '';
  position: absolute;
  bottom: 10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  background: #fff;
  border-radius: 50%;
}
.islogined{
  display: none;
}
/* 遮罩层 */
.ts-dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}
.hiddendialog{
  display: none;
}
/* 弹窗容器 */
.ts-dialog-container {
  width: 85%;
  background: #ffffff;
  border-radius: 40rpx;
  padding: 60rpx 40rpx;
  position: relative;
  box-sizing: border-box;
}

/* 头像设计 */
.ts-dialog-avatar-box {
  display: flex;
  justify-content: flex-start;
  margin-bottom: 40rpx;
}

.ts-dialog-avatar-circle {
  width: 120rpx;
  height: 120rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.ts-dialog-avatar-icon {
  font-size: 60rpx;
  color: #ccc;
}

.ts-dialog-edit-icon {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 36rpx;
  height: 36rpx;
  background: #ddd;
  border-radius: 50%;
  font-size: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #fff;
  border: 4rpx solid #fff;
}

/* 标题区 */
.ts-dialog-header {
  margin-bottom: 60rpx;
}

.ts-dialog-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.ts-dialog-subtitle {
  font-size: 26rpx;
  color: #999;
}

/* 表单区 */
.ts-form-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1px solid #f5f5f5;
  margin-bottom: 20rpx;
}

.ts-label {
  width: 120rpx;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.ts-required {
  color: #71602e; /* 必填符号使用品牌色 */
  margin-left: 4rpx;
}

.ts-input {
  flex: 1;
  font-size: 28rpx;
  padding-left: 20rpx;
}

.ts-placeholder {
  color: #ccc;
}

.ts-auth-btn {
  background: none;
  font-size: 24rpx;
  color: #eee; /* 还原图中未激活的淡色 */
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1;
}

/* 底部操作 */
.ts-dialog-footer {
  margin-top: 80rpx;
  text-align: center;
}

.ts-submit-btn {
  width: 100% !important;
  height: 90rpx;
  background: #eeeeee; /* 还原图中的灰色按钮 */
  color: #bbbbbb;
  border-radius: 45rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  margin-bottom: 30rpx;
}

.ts-skip-btn {
  font-size: 28rpx;
  color: #999;
}
/* --- 登录后状态追加样式 --- */

/* 登录后插画向上移动，给菜单留空间 */
.ts-illustration.is-logined-img {
  margin-top: 150rpx;
  opacity: 0.6; /* 登录后插画变淡，突出功能键 */
}

/* 登录后卡片样式调整：高度变矮，内容横向排列 */
.ts-logged-card {
  top: 180rpx !important;
  padding: 30rpx 40rpx !important;
  display: flex;
  align-items: center;
}

.ts-logged-user {
  display: flex;
  align-items: center;
  width: 100%;
}

.ts-user-avatar {
  width: 100rpx;
  height: 100rpx;
  background: #ccc;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 30rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
}

.ts-user-avatar image {
  width: 100%;
  height: 100%;
}

.ts-user-name {
  color: #ffffff;
  font-size: 34rpx;
  letter-spacing: 2rpx;
}

/* 登录后的虚线功能按钮列表 */
.ts-logged-menu {
  position: absolute;
  top: 480rpx; /* 位于卡片下方 */
  width: 80%;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.ts-menu-item {
  width: 100%;
  height: 90rpx;
  border: 1px dashed #71602e; /* 品牌色虚线框 */
  border-radius: 25rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #71602e;
  font-size: 30rpx;
  background-color: #fff;
}

.ts-menu-item:active {
  background-color: #f9f9f9;
  opacity: 0.8;
}
/* --- 验证加载弹窗样式 --- */
.ts-loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.8); /* 浅色半透明遮罩，更高级 */
  backdrop-filter: blur(4px); /* 磨砂玻璃效果 */
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 2000;
}

.ts-loading-container {
  width: 70%;
  background: #ffffff;
  border-radius: 40rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(113, 96, 46, 0.15); /* 带有品牌色的阴影 */
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  border: 1rpx solid rgba(113, 96, 46, 0.1);
}

/* 品牌色旋转动效 */
.ts-loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f5f5f5;
  border-top: 6rpx solid #71602e; /* 你的品牌主色 */
  border-radius: 50%;
  animation: ts-spin 1s linear infinite;
  margin-bottom: 40rpx;
}

@keyframes ts-spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.ts-loading-text {
  text-align: center;
}

.ts-loading-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #71602e;
  margin-bottom: 12rpx;
}

.ts-loading-subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
  letter-spacing: 1rpx;
}

/* 底部点缀虚线 */
.ts-loading-line {
  width: 60%;
  height: 1rpx;
  border-bottom: 2rpx dashed #71602e;
  margin-top: 40rpx;
  opacity: 0.3;
}

/* 复用你的隐藏类 */
.hiddendialog {
  display: none !important;
}