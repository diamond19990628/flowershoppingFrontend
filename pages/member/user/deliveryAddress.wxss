page {
  background-color: #fff;
  font-family: "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

/* 顶部装饰与标题 (保持与订单页一致) */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx dashed #A38E58;
  margin-bottom: 10rpx;
}
.slogan { font-size: 24rpx; color: #A38E58; }
.brand { font-size: 34rpx; color: #5C4A33; font-weight: 500; }

.header {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  position: relative;
}
.back-btn { position: absolute; left: 40rpx; }
.arrow-left {
  width: 20rpx; height: 20rpx;
  border-left: 4rpx solid #5C4A33;
  border-bottom: 4rpx solid #5C4A33;
  transform: rotate(45deg);
}
.title { font-size: 34rpx; color: #5C4A33; font-weight: 600; }

/* 内容区域 */
.content-area {
  padding: 40rpx;
}

/* 微信导入按钮：还原图中灰色大方块 */
.import-btn-box {
  background-color: #F3F4F6;
  height: 240rpx;
  border-radius: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 40rpx;
  color: #5C4A33;
  font-size: 32rpx;
}

/* 已设定地址卡片：延续订单卡片风格 */
.address-card {
  display: flex;
  align-items: center;
  background: #fff;
  border: 2rpx solid #E2DCC8; /* 浅棕色边框 */
  border-radius: 30rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-info {
  flex: 1;
}

.user-line {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.user-phone {
  font-size: 28rpx;
  color: #666;
}

.default-tag {
  font-size: 20rpx;
  color: #A38E58;
  background: #FDF9F0;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  margin-left: 20rpx;
  border: 1rpx solid #A38E58;
}

.address-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 修改按钮 */
.card-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-left: 30rpx;
  margin-left: 30rpx;
  border-left: 1rpx solid #EEE;
  color: #A38E58;
  font-size: 24rpx;
}

.edit-icon {
  width: 36rpx;
  height: 36rpx;
  margin-bottom: 8rpx;
}

/* 底部添加按钮 */
.add-address-btn {
  margin-top: 60rpx;
  background-color: #A38E58;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: normal;
  width: 80% !important;
}

/* 弹窗基础遮罩 */
.ts-dialog-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex; justify-content: center; align-items: center;
  z-index: 1000;
}
.hiddendialog { display: none; }

/* 弹窗容器 */
.ts-dialog-container {
  width: 85%;
  background: #ffffff;
  border-radius: 40rpx;
  padding: 50rpx 40rpx;
  box-sizing: border-box;
}

.ts-dialog-header { margin-bottom: 40rpx; }
.ts-dialog-title { font-size: 36rpx; font-weight: bold; color: #5C4A33; margin-bottom: 10rpx; }
.ts-dialog-subtitle { font-size: 24rpx; color: #999; }

/* 表单样式 */
.ts-form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

/* 地址栏特殊处理：上下排列以获得更多空间 */
.ts-area-item {
  flex-direction: column;
  align-items: flex-start;
  border-bottom: none;
}

.ts-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #5C4A33;
  font-weight: 500;
}

.ts-required { color: #A38E58; margin-left: 4rpx; }

.ts-input { flex: 1; font-size: 28rpx; padding-left: 20rpx; color: #333; }

.ts-textarea {
  width: 100%;
  height: 150rpx;
  background: #F9F9F9;
  border-radius: 12rpx;
  margin-top: 20rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
}

.ts-placeholder { color: #ccc; }

/* 底部按钮 */
.ts-dialog-footer { margin-top: 50rpx; text-align: center; }

.ts-confirm-btn {
  width: 100% !important;
  height: 90rpx;
  background: #A38E58; /* 品牌金棕色 */
  color: #fff;
  border-radius: 45rpx;
  display: flex; justify-content: center; align-items: center;
  font-size: 30rpx;
  margin-bottom: 24rpx;
}

.ts-cancel-btn {
  font-size: 28rpx;
  color: #999;
  padding: 10rpx;
}
/* 删除弹窗专用容器：稍微窄一点，显得更轻量 */
.delete-dialog {
  width: 75% !important;
  padding: 60rpx 40rpx 40rpx !important;
}

/* 顶部的警告感叹号图标 */
.delete-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  background-color: #FFF1F0; /* 浅红色背景 */
  border: 2rpx solid #FF4D4F;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 auto;
}

.warning-mark {
  color: #FF4D4F;
  font-size: 50rpx;
  font-weight: bold;
}

/* 覆盖确认按钮颜色为警告红 */
.delete-confirm {
  background: #FF4D4F !important;
  box-shadow: 0 8rpx 20rpx rgba(255, 77, 79, 0.2);
}

/* 取消按钮稍微加点边距 */
.ts-cancel-btn {
  margin-top: 20rpx;
  display: block;
}