/* --- 1. 全屏基础布局 --- */
page {
  height: 100%;
}

.full-page {
  width: 100vw;
  height: 100vh;
  background-color: #7A6E39;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.status-bar {
  flex-shrink: 0;
  height: 44px; /* 建议根据机型动态获取，此处设为常规模拟值 */
}

.header-section {
  flex-shrink: 0;
  height: 10vh;
  display: flex;
  justify-content: center;
  align-items: center;
}

.tab-pill {
  border: 1rpx dashed rgba(255,255,255,0.7);
  border-radius: 50rpx;
  padding: 12rpx 70rpx;
  color: #fff;
  font-size: 34rpx;
}

.swap-icon {
  margin-left: 15rpx;
}

/* --- 2. 白色主卡片区域 --- */
.main-card {
  flex: 1;
  background-color: #fff;
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  display: flex;
  flex-direction: column;
  padding: 0 40rpx;
  overflow: hidden;
}

/* --- 3. 统一的选择行样式 (List-Row) --- */
.select-group {
  margin-top: 10rpx;
  flex-shrink: 0;
}

/* 关键修复：让 picker 和普通的 view 在视觉上完全一致 */
.list-row {
  display: flex; /* 基础设为 flex */
  background-color: #F7F7F7;
  height: 106rpx;
  margin-top: 20rpx;
  border-radius: 8rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
  align-items: center;
  justify-content: space-between;
  color: #7A6E39;
  font-size: 32rpx;
}

/* 当 list-row 是 picker 组件时的特殊处理 */
picker.list-row {
  display: block; /* picker 必须为 block */
}

/* picker 内部的容器，模拟 flex 布局 */
.picker-inner-container {
  width: 100%;
  height: 106rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.picker-content{
  height: 106rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.picker-value-wrap {
  display: flex;
  align-items: center;
}

/* 文字状态样式 */
.placeholder-text {
  color: #ccc;
  font-size: 28rpx;
}

.selected-text {
  color: #7A6E39;
  font-weight: 500;
  max-width: 380rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chevron {
  width: 14rpx;
  height: 14rpx;
  border-top: 3rpx solid #7A6E39;
  border-right: 3rpx solid #7A6E39;
  transform: rotate(45deg);
  margin-left: 15rpx;
  flex-shrink: 0;
}

/* --- 4. 商品滚动区域 --- */
.product-scroll {
  flex: 1;
  margin-top: 20rpx;
  height: 10rpx; /* 触发 flex 滚动 */
}

.divider {
  height: 1rpx;
  background-color: #E0D8C0;
  margin: 10rpx 0;
}

.product-body {
  display: flex;
  padding: 25rpx 0;
}

.img-box {
  width: 160rpx;
  height: 160rpx;
  background-color: #E8E8E8;
  border-radius: 8rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.img-box image {
  width: 100%;
  height: 100%;
}

.info-box {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.name {
  color: #7A6E39;
  font-size: 30rpx;
  font-weight: 500;
}

.price {
  color: #7A6E39;
  font-size: 34rpx;
  font-weight: bold;
  margin-top: 10rpx;
}

.card-name {
  font-size: 24rpx;
  color: #888;
}

.tag {
  align-self: flex-start;
  background-color: #F5F5F5;
  color: #999;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  margin-top: 8rpx;
}

/* --- 5. 合计与按钮 --- */
.total-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 10rpx;
  border-top: 1rpx solid #f5f5f5;
  flex-shrink: 0;
}

.total-label {
  font-size: 32rpx;
  font-weight: bold;
}

.total-amount {
  color: #7A6E39;
}

.total-amount .number {
  font-size: 46rpx;
  font-weight: bold;
}

.action-area {
  flex-shrink: 0;
  padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

button {
  width: 100% !important;
  height: 94rpx;
  line-height: 94rpx;
  border-radius: 47rpx;
  font-size: 32rpx;
  margin-bottom: 20rpx;
  display: flex;              /* ✅ 真正居中 */
  align-items: center;        /* 垂直居中 */
  justify-content: center;    /* 水平居中 */
}

.btn-gold {
  background-color: #7A6E39;
  color: #fff;
}

.btn-ghost {
  background-color: #F4F5F9;
  color: #3B4461;
}
.pay-loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.38);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.pay-loading-dialog {
  width: 470rpx;
  padding: 48rpx 36rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.98);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.12);
}

.spinner-wrapper {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.spinner-ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 8rpx solid rgba(212, 175, 55, 0.18);
  border-top: 8rpx solid #d4af37;
  animation: payRotate 0.9s linear infinite;
  box-sizing: border-box;
}

.spinner-core {
  position: absolute;
  font-size: 38rpx;
  font-weight: 600;
  color: #d4af37;
  line-height: 1;
}

.pay-loading-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.pay-loading-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
  text-align: center;
}

@keyframes payRotate {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}
/* ===== 运费 Dialog（完全隔离版） ===== */
.fee-dialog-mask {
  position: fixed;
  inset: 0;
  z-index: 9999;

  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s ease;
}

.fee-dialog-mask.show {
  opacity: 1;
  pointer-events: auto;
}

/* 背景遮罩 */
.fee-dialog-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
}

/* 卡片 */
.fee-dialog-card {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0.96);

  width: 560rpx;
  padding: 36rpx 32rpx 28rpx;
  border-radius: 24rpx;

  /* 和你主色 #7A6E39 统一 */
  background: linear-gradient(180deg, #fffaf3 0%, #f3eadc 100%);

  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.18);
  border: 1rpx solid rgba(122, 110, 57, 0.15);

  transition: transform 0.2s ease;
}

.fee-dialog-mask.show .fee-dialog-card {
  transform: translate(-50%, -50%) scale(1);
}

/* 标题 */
.fee-dialog-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #7A6E39;
  text-align: center;
  margin-bottom: 18rpx;
}

/* 内容 */
.fee-dialog-text {
  font-size: 28rpx;
  color: #5f4f22;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 30rpx;
}

/* 按钮区 */
.fee-dialog-footer {
  display: flex;
  gap: 20rpx;
}

/* 按钮（避免污染你原来的 button 样式） */
.fee-dialog-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 999rpx;

  display: flex;
  align-items: center;
  justify-content: center;

  font-size: 26rpx;
  font-weight: 600;

  transition: all 0.15s ease;
}

/* 取消按钮 */
.fee-dialog-btn-cancel {
  background: #F4F5F9; /* 用你现有 ghost 风格 */
  color: #7A6E39;
}

/* 确定按钮 */
.fee-dialog-btn-confirm {
  background-color: #7A6E39; /* 完全复用你主色 */
  color: #ffffff;
}

/* 点击反馈 */
.fee-dialog-btn:active {
  transform: scale(0.96);
  opacity: 0.85;
}

.address-picker {
  flex: 1;
  height: 106rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.row-label {
  display: flex;
  align-items: center;
  height: 106rpx;
  line-height: 1;
}

.placeholder-text,
.selected-text {
  display: flex;
  align-items: center;
  line-height: 1;
  margin-bottom: 30rpx;
}

.chevron {
  margin-left: 15rpx;
}