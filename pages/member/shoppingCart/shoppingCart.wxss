page {
  background: #71602e;
}

.cart-page {
  min-height: 100vh;
}

/* 顶部标题 */
.cart-header {
  height: 180rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.cart-title {
  color: #ffffff;
  font-size: 36rpx;
  letter-spacing: 2rpx;
}

/* 白色内容区 */
.cart-card {
  width: 100%;
  min-height: calc(100vh - 180rpx);
  background: #ffffff;
  border-radius: 50rpx 50rpx 0 0;
  padding: 40rpx 40rpx 300rpx;
  box-sizing: border-box;
}

.cart-item {
  margin-bottom: 30rpx;
}

.item-main {
  display: flex;
  padding: 20rpx 0;
}

.item-image {
  width: 218rpx;
  height: 216rpx;
  background: #d9d9d9;
  border-radius: 12rpx;
}
.item-image image{
  width: 100%;
  height: 100%;
}

.item-center {
  flex: 1;
  padding: 10rpx 20rpx;
}

.item-name {
  font-size: 28rpx;
  color: #71602e;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.item-price {
  font-size: 32rpx;
  color: #71602e;
  font-weight: bold;
}

/* 右侧操作 */
.item-right {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: flex-end;
  padding: 10rpx 0;
}

.item-check-icon {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #71602e;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
}

.item-check-icon.is-active {
  background: #71602e;
  color: #fff;
}

.item-count {
  display: flex;
  align-items: center;
  border: 2rpx solid #afe3f1;
  border-radius: 8rpx;
  height: 48rpx;
}

.count-btn {
  width: 48rpx;
  text-align: center;
  color: #afe3f1;
  font-size: 32rpx;
}

.count-num {
  width: 50rpx;
  text-align: center;
  font-size: 26rpx;
  border-left: 2rpx solid #afe3f1;
  border-right: 2rpx solid #afe3f1;
}

/* --- 附属配置区样式 --- */
.item-config-area {
  background-color: #f9f7f2;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-top: 10rpx;
}

.config-row {
  display: flex;
  margin-bottom: 20rpx;
}

.config-label {
  font-size: 24rpx;
  color: #71602e;
  width: 100rpx;
  font-weight: bold;
}

.config-content {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.config-tag {
  background: #fff;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  color: #888;
  border: 1rpx solid #eee;
}

.config-tag-arrow {
  font-size: 18rpx;
  color: #ccc;
}

.config-textarea-static {
  flex: 1;
  background: #fff;
  border-radius: 12rpx;
  padding: 15rpx;
  font-size: 24rpx;
  color: #666;
  min-height: 60rpx;
  border: 1rpx solid #eee;
}

/* 自定义单选样式 (静态模拟) */
.config-anonymous {
  display: flex;
  justify-content: flex-end;
}

.anonymous-group {
  display: flex;
}

.radio-item {
  display: flex;
  align-items: center;
  margin-left: 30rpx;
  font-size: 24rpx;
  color: #71602e;
}

.radio-circle {
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid #71602e;
  border-radius: 50%;
  margin-right: 10rpx;
  position: relative;
}

.radio-circle.active::after {
  content: '';
  width: 14rpx;
  height: 14rpx;
  background: #71602e;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}
/* 当父级 .radio-item 有 active 类时，它内部的 .radio-circle 显示实心点 */
.radio-item.active .radio-circle::after {
  content: '';
  width: 14rpx;
  height: 14rpx;
  background: #71602e;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: block; /* 确保显示 */
}
.item-divider {
  height: 1rpx;
  background: #71602e;
  opacity: 0.1;
  margin: 30rpx 0 10rpx;
}

/* 结算按钮 */
.bottom-bar {
  position: fixed;
  bottom: 200rpx;
  left: 0;
  width: 100%;
  display: flex;
  justify-content: center;
}

.checkout-btn {
  width: 280rpx;
  height: 88rpx;
  background: #71602e;
  color: #ffffff;
  border-radius: 44rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 10rpx 20rpx rgba(113, 96, 46, 0.3);
}