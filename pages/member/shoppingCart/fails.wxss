/* 页面整体 */
.container {
  height: 100vh;
  background: #f7f7f7;

  display: flex;
  justify-content: center;
  align-items: center;
}

/* 卡片 */
.card {
  width: 85%;
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;

  display: flex;
  flex-direction: column;
  align-items: center;

  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.05);
}

/* 图标 */
.icon {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  text-align: center;

  border-radius: 50%;
  background: #8c7a3b;
  color: #fff;

  font-size: 70rpx;
  margin-bottom: 30rpx;
}

/* 标题 */
.title {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

/* 描述 */
.desc {
  font-size: 26rpx;
  color: #666;
}

.desc.sub {
  margin-top: 6rpx;
  margin-bottom: 40rpx;
  color: #999;
}

/* 按钮 */
.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

/* 主按钮 */
.btn.primary {
  background: #8c7a3b;
  color: #fff;
}

/* 次按钮（空心） */
.btn.ghost {
  border: 2rpx solid #8c7a3b;
  color: #8c7a3b;
  background: #fff;
}