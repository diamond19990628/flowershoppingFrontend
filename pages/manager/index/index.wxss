/* pages/manager/index.wxss */
.admin-container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding: 30rpx;
}

/* 顶部样式 */
.header {
  margin-bottom: 40rpx;
  padding: 20rpx 10rpx;
}
.avatar {
  width: 100rpx;
  height: 100rpx;
  background: #07c160;
  border-radius: 50%;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  margin-right: 20rpx;
}
.user-info { display: flex; align-items: center; }
.title { font-size: 40rpx; font-weight: bold; display: block; }
.subtitle { font-size: 24rpx; color: #999; }

/* 数据看板 */
.stat-card {
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  padding: 40rpx 0;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0,0.05);
}
.stat-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid #eee;
}
.stat-item:last-child { border-right: none; }
.num { font-size: 36rpx; font-weight: bold; color: #333; display: block; }
.label { font-size: 24rpx; color: #666; margin-top: 10rpx; }

/* 按钮网格布局 */
.menu-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.menu-item {
  width: 330rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 0;
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  transition: all 0.2s;
}
.btn-hover { background-color: #f0f0f0; transform: scale(0.98); }

.icon-box {
  width: 100rpx;
  height: 100rpx;
  border-radius: 30rpx;
  font-size: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

/* 按钮颜色配置 */
.bg-blue { background: #eef5fe; color: #2F54EB; }
.bg-orange { background: #fff7e6; color: #fa8c16; }
.bg-green { background: #f6ffed; color: #52c41a; }
.bg-red { background: #fff1f0; color: #f5222d; }

.menu-name { font-size: 30rpx; font-weight: 600; color: #333; }
.menu-desc { font-size: 22rpx; color: #999; margin-top: 8rpx; }

/* 红点标记 */
.badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: #ff4d4f;
  color: white;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
}

.logout-btn {
  margin-top: 60rpx;
  background: #fff;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
  font-size: 28rpx;
  border-radius: 50rpx;
}