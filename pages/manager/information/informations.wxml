<view class="container">
  <view class="fixed-header">
    <view class="admin-hero">
      <view class="hero-left">
        <text class="hero-title">公告管理中心</text>
        <text class="hero-desc">管理系统展示与提醒</text>
      </view>
      <view class="btn-create" hover-class="btn-active" bind:tap="openDialog">
        <text class="plus">+</text> 发布公告
      </view>
    </view>
  </view>

  <view class="content-body">
    <view class="card" wx:for="{{informationList}}" wx:key="index">
      <view class="card-main" data-information_id="{{item.informationId}}">
        <view class="card-row-top">
          <text class="title-text">{{item.informationTitle}}</text>
          <view class="status-tag">进行中</view>
        </view>

        <view class="content-text">
          {{item.informationContent}}
        </view>

        <view class="duration-box">
          <text class="time-label">显示期限：</text>
          <text class="time-range">{{item.publishStartDate}} 至 {{item.publishEndDate}}</text>
        </view>
      </view>

      <view class="card-footer">
        <view class="footer-btn edit">编辑内容</view>
        <view class="footer-btn delete">删除</view>
      </view>
    </view>
  </view>
</view>

<view class="dialog-mask {{showDialog ? 'show' : ''}}" bindtap="closeDialog"></view>

<view class="dialog-container {{showDialog ? 'show' : ''}}">
  <view class="dialog-header">
    <text class="dialog-title">发布新公告</text>
    <view class="close-icon" bindtap="closeDialog">×</view>
  </view>

  <scroll-view scroll-y="true" class="dialog-body">
    <view class="input-group">
      <text class="label">公告标题</text>
      <input class="input-element" placeholder="请输入标题（20字以内）" placeholder-class="p-class" data-field="information_title" bindinput="onInput"/>
    </view>

    <view class="input-group">
      <text class="label">公告内容</text>
      <textarea class="textarea-element" placeholder="请输入详细公告内容..." maxlength="500" bindinput="onInput" data-field="information_content"></textarea>
    </view>

    <view class="date-group">
      <view class="date-item">
        <text class="label">开始日期</text>
        <picker mode="date" value="{{startDate}}" bindchange="bindStartDateChange">
          <view class="picker-field">{{startDate || '请选择'}}</view>
        </picker>
      </view>
      <view class="date-item">
        <text class="label">结束日期</text>
        <picker mode="date" value="{{endDate}}" bindchange="bindEndDateChange">
          <view class="picker-field">{{endDate || '请选择'}}</view>
        </picker>
      </view>
    </view>
  </scroll-view>

  <view class="dialog-footer">
    <view class="btn-cancel" bindtap="closeDialog">取消</view>
    <view class="btn-confirm" bindtap="submitNotice">立即发布</view>
  </view>
</view>
<errorDialog isErrorVisible="{{isErrorVisible}}" errorMessage="{{errorMessage}}"/>