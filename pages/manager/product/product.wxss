/* pages/manager/product/product.wxss */
/* 基础容器 */
.admin-container {
  min-height: 100vh;
  background-color: #f7f8fa;
  box-sizing: border-box;
}

.fixed-top {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #f7f8fa;
  padding: 20rpx 30rpx 16rpx;
  box-sizing: border-box;
}
.fixed-top-placeholder{
  height: 210rpx;
}
.goods-list {
  height: calc(100vh - 210rpx);
  padding: 20rpx 30rpx;
  box-sizing: border-box;
}
/* 搜索与新增 */
.search-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.search-bar {
  flex: 1;
  height: 80rpx;
  background: #fff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  padding: 0 12rpx 0 30rpx;
  margin-right: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
  box-sizing: border-box;
}
.search-bar input { margin-left: 15rpx; font-size: 26rpx; }

.add-btn {
  width: 160rpx;
  height: 80rpx;
  background: #07c160;
  color: #fff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}
.add-icon {
  font-size: 36rpx;
  margin-right: 6rpx;
}


/* 状态标签 */
.tabs {
  display: flex;
  justify-content: space-between;
  margin-bottom: 0;
  background: #f7f8fa;
}
.tab-item {
  font-size: 26rpx;
  color: #666;
  padding: 10rpx 20rpx;
}
.tab-item.active {
  color: #07c160;
  font-weight: bold;
  position: relative;
}
.tab-item.active::after {
  content: "";
  position: absolute;
  bottom: -4rpx;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background: #07c160;
}

/* 商品卡片列表 */
.goods-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
}
.goods-info { display: flex; align-items: center; }
.goods-img {
  width: 140rpx;
  height: 140rpx;
  background: #f0f0f0;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  overflow: hidden;
  flex-shrink: 0;
}
.goods-detail {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}
.goods-title { font-size: 30rpx; font-weight: bold; color: #333; }
.goods-sku { font-size: 22rpx; color: #999; margin-top: 6rpx; }

.goods-price-row {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}
.price { color: #f5222d; font-size: 32rpx; font-weight: bold; }
.stock { font-size: 24rpx; color: #666; }

/* 操作按钮 */
.goods-ops {
  margin-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
  display: flex;
  justify-content: flex-end;
}
.op-btn.mini {
  margin-left: 20rpx;
  margin-right: 0;
  font-size: 24rpx;
  background: #f7f8fa;
  color: #333;
  border-radius: 30rpx;
  line-height: 2.2;
}
.op-btn.warning { color: #fa8c16; }

/* 遮罩层 */
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  align-items: flex-end;
  z-index: 1000;

  /* 关键：默认完全不渲染，防止真机首帧闪内容 */
  display: none;
}

/* 打开时再显示 */
.dialog-mask.show {
  display: flex;
  animation: dialogMaskFadeIn 0.25s ease;
}

/* 弹窗主体 */
.dialog-container {
  width: 100%;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 0;

  /* 默认状态 */
  transform: translateY(100%);
}

/* 打开时播放上滑动画 */
.dialog-mask.show .dialog-container {
  animation: dialogSlideUp 0.3s ease forwards;
}

@keyframes dialogMaskFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes dialogSlideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.dialog-header {
  padding: 0 40rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.dialog-title { font-size: 34rpx; font-weight: bold; }
.close-icon { color: #ccc; font-size: 40rpx; padding: 10rpx; }

.dialog-content {
  max-height: 70vh;
  padding: 0 40rpx;
}

/* 表单项样式 */
.form-item { margin-bottom: 30rpx; }
.form-row { display: flex; justify-content: space-between; }
.form-item.half { width: 48%; }

.form-label {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}
.form-input {
  background: #f7f8fa;
  height: 90rpx;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}
.picker-input { line-height: 90rpx; color: #999; }

/* 上传框 */
.upload-box {
  width:200rpx;
  height:200rpx;
  border:2rpx dashed #ccc;

  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;

  position:relative;
  overflow:hidden;
}
.upload-image{
  width:100%;
  height:100%;
}
.upload-plus { font-size: 50rpx; color: #999; margin-bottom: 6rpx; }
.upload-tip { font-size: 20rpx; color: #999; }

/* 底部按钮 */
.dialog-footer {
  padding: 40rpx;
  display: flex;
  justify-content: space-between;
}
.btn-cancel {
  width: 30%;
  background: #f5f5f5;
  color: #666;
  border-radius: 45rpx;
  font-size: 28rpx;
}
.btn-confirm {
  width: 65%;
  background: #07c160; /* 统一样式颜色 */
  color: #fff;
  border-radius: 45rpx;
  font-size: 28rpx;
}
/* 遮罩层和容器样式沿用之前的 */
.full-screen-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0, 0, 0, 0.7); /* 稍微加深一点背景，突出动画 */
  display: flex; justify-content: center; align-items: center;
  z-index: 9999;
}

.loading-container {
  display: flex; flex-direction: column; align-items: center;
}

.loading-text {
  color: #ffffff; font-size: 28rpx; margin-top: 30rpx; /* 增加一点间距 */
  letter-spacing: 2rpx; /* 文字间距，看起来更有质感 */
}

/* =========================================
   核心 CSS 上传动画 - 旋转圆环
   ========================================= */
.upload-loader {
  width: 80rpx;  /* 动画尺寸 */
  height: 80rpx; /* 动画尺寸 */
  border: 8rpx solid #e0e0e0; /* 底色圆环 */
  border-radius: 50%; /* 变成圆 */
  
  /* 旋转的部分：设置右边（或任意一边）为透明，或者设置不同的颜色 */
  border-right-color: transparent; 
  /* 如果想要微信官方那种绿色，可以用 #07C160 */
  border-top-color: #007aff; /* 活跃部分的颜色 (例如蓝色) */

  /* 定义动画：名称 时长 时间函数 无限循环 */
  animation: upload-spin 0.8s linear infinite;
}

/* 定义旋转关键帧 */
@keyframes upload-spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

.search-bar {
  flex: 1;
  height: 80rpx;
  background: #fff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  padding: 0 12rpx 0 30rpx;
  margin-right: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
}

.search-input {
  flex: 1;
  margin-left: 15rpx;
  font-size: 26rpx;
  min-width: 0;
}

.search-btn {
  flex-shrink: 0;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 28rpx;
  background: #f2fbf6;
  color: #07c160;
  font-size: 24rpx;
  font-weight: 500;
  border: 1rpx solid #d9f2e3;
  text-align: center;
  box-sizing: border-box;
}