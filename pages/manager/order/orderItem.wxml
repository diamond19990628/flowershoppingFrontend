<view class="detail-container">
  <view class="status-header">
    <view class="status-text">
      <text class="status-title">{{orderItems.status.statusName}}</text>
      <text class="status-desc" wx:if="{{orderItems.status.statusId === 1}}">请及时处理发货，避免超时</text>
    </view>
    <view class="status-icon">🚚</view>
  </view>

  <view class="section-card address-card">
    <view class="section-title">收货信息</view>
    <view class="address-content">
      <view class="user-info">
        <text class="name">{{orderItems.user.nickName}}</text>
        <text class="phone">{{orderItems.user.tel}}</text>
      </view>
      <view class="address-detail">{{orderItems.deliveryAddress.delivery_address}}</view>
      <view>{{orderItems.deliverytype.delivery_type_name}}</view>
    </view>
    <button class="copy-btn" size="mini" plain bindtap="copyText" data-text="{{orderItems.deliveryAddress.delivery_address}}">复制地址</button>
  </view>

  <view class="section-card">
    <view class="section-title">商品清单</view>

    <view class="goods-item" wx:for="{{orderItems.order_items}}" wx:key="index" wx:for-item="orderItem">
      <image class="goods-img" src="{{orderItem.attachedFilePath}}" mode="aspectFill"></image>

      <view class="goods-info">
        <text class="goods-name">{{orderItem.product.productName}}</text>

        <view class="goods-price-row">
          <text class="price">¥{{orderItem.product.amount}}</text>
          <text class="count">x{{orderItem.quantity}}</text>
        </view>

        <view class="goods-extra">
          <view class="goods-extra-item">
            <text class="goods-extra-label">卡片</text>
            <text class="goods-extra-value">{{orderItem.card.card_name}}</text>
          </view>

          <view class="goods-extra-item">
            <text class="goods-extra-label">备注</text>
            <text class="goods-extra-value">{{orderItem.comment || '无'}}</text>
          </view>
        </view>
      </view>
    </view>
    
    <view class="fee-list">
      <view class="fee-item">
        <text>商品总额</text>
        <text>¥{{orderItems.total_amount}}</text>
      </view>
      <view class="fee-item">
        <text>实付款</text>
        <text class="total-val">¥{{orderItems.total_amount}}</text>
      </view>
    </view>
  </view>

  <view class="section-card order-info">
    <view class="info-item">
      <text class="label">订单编号</text>
      <view class="val">{{orderItems.order_no}} <text class="copy-link" data-text="{{orderItems.order_no}}" bind:tap="copyText">复制</text></view>
    </view>
    <view class="info-item">
      <text class="label">下单时间</text>
      <text class="val">{{orderItems.create_time}}</text>
    </view>
    <view class="info-item">
      <text class="label">{{orderItems.deliverytype.delivery_type_name}}时间</text>
      <text class="val">{{orderItems.delivery_date}}</text>
    </view>
  </view>

  <view class="section-card memo-section" wx:if="{{order.memo}}">
    <view class="section-title">后台备注</view>
    <view class="memo-box">{{order.memo}}</view>
  </view>

  <view style="height: 160rpx;"></view>

  <view class="bottom-bar">
    <button class="bar-btn secondary" bindtap="editMemo">修改备注</button>
    <button class="bar-btn primary" wx:if="{{order.status.statusId === 1}}">去发货</button>
    <button class="bar-btn warn" wx:if="{{order.status.statusId === 2}}">拒绝退款</button>
  </view>
</view>