/* 延用之前的背景色和字体 */
.detail-container {
  padding: 20rpx;
  background-color: #f4f6f8;
  min-height: 100vh;
}

/* 顶部状态栏 */
.status-header {
  background: linear-gradient(135deg, #00c677 0%, #00ab66 100%);
  padding: 60rpx 40rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  color: #fff;
}
.status-title { font-size: 40rpx; font-weight: bold; display: block; }
.status-desc { font-size: 24rpx; opacity: 0.9; margin-top: 10rpx; }
.status-icon { font-size: 60rpx; }

/* 通用卡片 */
.section-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  border-left: 8rpx solid #00c677;
  padding-left: 16rpx;
}

/* 地址样式 */
.address-card { position: relative; }
.user-info { margin-bottom: 10rpx; }
.user-info .name { font-size: 32rpx; font-weight: bold; margin-right: 20rpx; }
.address-detail { font-size: 26rpx; color: #666; line-height: 1.5; padding-right: 120rpx; }
.copy-btn {
  position: absolute;
  right: 30rpx;
  top: 80rpx;
  border-color: #00c677 !important;
  color: #00c677 !important;
}

/* 商品清单 */
.goods-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}
.goods-img { width: 120rpx; height: 120rpx; border-radius: 12rpx; margin-right: 20rpx; }
.goods-info { flex: 1; }
.goods-name { font-size: 28rpx; color: #333; display: block; }
.goods-spec { font-size: 22rpx; color: #999; margin-top: 8rpx; }
.goods-price-row {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
}
.price { color: #ff4d4f; font-weight: bold; }

/* 费用明细 */
.fee-list { margin-top: 20rpx; }
.fee-item {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
}
.fee-total {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
  margin-top: 10rpx;
}
.total-val { font-size: 36rpx; font-weight: bold; color: #ff4d4f; margin-left: 20rpx; }

/* 订单信息 */
.info-item {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  margin-bottom: 20rpx;
}
.label { color: #999; }
.val { color: #333; }
.copy-link { color: #00c677; margin-left: 10rpx; }

/* 备注框 */
.memo-box {
  background: #fff8e6;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #856404;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05);
}
.bar-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
}
.secondary { background: #f5f5f5; color: #666; }
.primary { background: #00c677; color: #fff; }
.warn { background: #ff4d4f; color: #fff; }