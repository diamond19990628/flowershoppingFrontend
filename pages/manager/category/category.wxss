/* 引入原有基础样式 */
page { background-color: #f4f6f8; font-family: "PingFang SC", sans-serif; }

.fixed-top {
  position: fixed; top: 0; left: 0; right: 0;
  background: #fff; z-index: 100; border-bottom: 1rpx solid #eee;
}

.search-section { padding: 20rpx 30rpx; }
.search-input-inner {
  background: #f1f1f1; height: 72rpx; border-radius: 36rpx;
  display: flex; align-items: center; padding: 0 30rpx;
}

.admin-tabs {
  display: flex; justify-content: space-between; align-items: center;
  padding: 10rpx 30rpx; height: 80rpx;
}

.add-main-btn {
  font-size: 26rpx; color: #fff; background: #00c677;
  padding: 10rpx 24rpx; border-radius: 30rpx; font-weight: bold;
}

/* 分类卡片 */
.order-scroll-view { margin-top: 180rpx; padding: 20rpx; box-sizing: border-box; }

.category-card {
  background: #fff; border-radius: 20rpx; margin-bottom: 24rpx;
  overflow: hidden; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.parent-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 30rpx; background: #fff;
}

.parent-info { display: flex; align-items: center; flex: 1; }
.expand-icon { font-size: 20rpx; color: #ccc; margin-right: 20rpx; width: 30rpx; }
.cate-icon { width: 60rpx; height: 60rpx; border-radius: 8rpx; background: #f0f0f0; margin-right: 20rpx; }
.parent-name { font-size: 32rpx; font-weight: bold; color: #333; }
.child-count { font-size: 22rpx; color: #999; margin-left: 16rpx; background: #f0f0f0; padding: 2rpx 12rpx; border-radius: 20rpx; }

.parent-actions text { font-size: 26rpx; margin-left: 20rpx; }
.edit-text { color: #00c677; }
.add-text { color: #576b95; }

/* 子分类列表 */
.child-list {
  display: none; background: #fafafa; padding: 0 30rpx;
  border-top: 1rpx solid #f1f1f1;
}
.child-list.show { display: block; }

.child-item {
  display: flex; justify-content: space-between; align-items: center;
  height: 100rpx; border-bottom: 1rpx solid #eee;
}
.child-item:last-child { border-bottom: none; }

.child-left { display: flex; align-items: center; }
.line-branch {
  width: 30rpx; height: 40rpx; border-left: 4rpx solid #ddd;
  border-bottom: 4rpx solid #ddd; margin-right: 20rpx; margin-top: -20rpx;
}
.child-img { width: 50rpx; height: 50rpx; border-radius: 6rpx; margin-right: 15rpx; }
.child-name { font-size: 28rpx; color: #444; }

.child-right { display: flex; gap: 30rpx; }

.card-footer {
  padding: 20rpx 30rpx; display: flex; justify-content: flex-end;
  gap: 20rpx; background: #fff; border-top: 1rpx solid #f8f8f8;
}

.btn-warn { background: #fff1f0; color: #ff4d4f; border: 1rpx solid #ffa39e; }
.btn-secondary { background: #f5f5f5; color: #666; border: 1rpx solid #d9d9d9; }

/* 弹窗外层容器 */
.category-dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2000;

  /* 关键：默认直接不渲染，避免真机首帧闪文字 */
  display: none;

  align-items: center;
  justify-content: center;
}

/* 显示时再渲染，并播放动画 */
.category-dialog-mask.modal-visible {
  display: flex;
  animation: categoryMaskFadeIn 0.2s ease-in-out;
}

.modal-backdrop {
  position: absolute;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
  z-index: 0;
}

.category-dialog-content {
  width: 560rpx;
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  position: relative;
  z-index: 1;

  transform: scale(0.9);
}

/* 显示时播放弹窗缩放动画 */
.modal-visible .category-dialog-content {
  animation: categoryDialogPopIn 0.2s ease-in-out forwards;
}
@keyframes categoryMaskFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes categoryDialogPopIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}
.dialog-header { padding: 45rpx 40rpx 15rpx; text-align: center; }
.dialog-title { font-size: 32rpx; font-weight: bold; color: #333; }

.dialog-body { padding: 30rpx 45rpx 45rpx; }
.single-input {
  background: #f6f7f8;
  height: 96rpx;
  border-radius: 20rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  text-align: center;
  border: 1rpx solid #eee;
}

.dialog-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.dialog-btn {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 30rpx;
}

.btn-cancel {
  color: #999;
  border-right: 1rpx solid #f0f0f0;
}

.btn-confirm {
  color: #00c677; /* 匹配你页面的主色 */
  font-weight: bold;
}

.dialog-btn:active {
  background: #f9f9f9;
}

/* 删除弹窗特有样式 */
.delete-tips {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  text-align: center;
}

.highlight-name {
  color: #333;
  font-weight: bold;
  padding: 0 4rpx;
}

.btn-delete {
  color: #ff4d4f; /* 警示红 */
  font-weight: bold;
}

/* 按钮点击反馈 */
.btn-delete:active {
  background: #fff1f0;
}

/* 错误图标样式 */
.error-icon-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #fff1f0;
  color: #ff4d4f;
  font-size: 50rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
  border: 4rpx solid #ff4d4f;
}

/* 错误文字信息 */
.error-message {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  line-height: 1.5;
  padding: 0 20rpx;
}

/* 错误弹窗的确定按钮 */
.btn-error-confirm {
  color: #333;
  font-weight: bold;
  background-color: #f5f5f5; /* 灰色背景，让用户感知这不是一个提交动作 */
}

.btn-error-confirm:active {
  background-color: #eeeeee;
}

/* 子分类右侧操作区域容器 */
.child-right {
  display: flex;
  align-items: center;
  gap: 0; /* 配合分割线使用，如果不想要分割线可以调大 gap */
}

/* 子分类操作按钮通用样式 */
.child-action-btn {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  transition: all 0.2s;
}

/* 具体的颜色定义（复用你已有的配色） */
.edit-text {
  color: #00c677; /* 你的主绿 */
}

.delete-text {
  color: #ff4d4f; /* 你的删除红 */
}

/* 点击态：背景微变色，让用户知道点中了 */
.edit-text:active {
  background-color: rgba(0, 198, 119, 0.1);
  opacity: 0.7;
}

.delete-text:active {
  background-color: rgba(255, 77, 79, 0.1);
  opacity: 0.7;
}

/* 中间的细分割线 */
.action-divider {
  width: 1rpx;
  height: 20rpx;
  background-color: #eee;
  margin: 0 10rpx;
}