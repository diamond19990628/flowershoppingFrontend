/* pages/common/header.wxss */
/* 底部 TabBar */
.custom-tab-bar {
  position: fixed;
  bottom: 0;
  width: 100%;
  height: 110rpx;
  background-color: #fcfaf7;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #333;
}
/* 底部 TabBar 图标样式 - 已移除边框 */
.tab-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 4rpx;
  border: none; 
}
.tab-item text{
  font-size: 30rpx;
}