
.header_body {
  position: fixed;
  /* 关键：利用环境变量适配刘海屏和状态栏 */
  top: 0;
  padding-top: env(safe-area-inset-top); 
  background: #fcfaf7; /* 确保背景色一直涂到最顶端 */
  left: 25rpx;
  right: 25rpx;
  z-index: 999;
}
.header_body_placeholder{
  height: 620rpx;
}
/* 1. Header */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 100rpx;
}
.logo-text {
  width: 104rpx;
  height: 100rpx;
}
.logo-text image{
  width: 100%;
  height: 100%;
  display: block;
}
.notice-btn {
  width: 72rpx;
  height: 68rpx;
  border: 2rpx solid rgba(55, 73, 87, 0.2);
  display: flex;
  justify-content: center;  /* 水平居中 */
  align-items: center;      /* 垂直居中 */
  border-radius: 20rpx;
}
.notice-btn image{
  width: 44rpx;
  height: 36rpx;
  display: block;
  margin: auto auto;
}

/* 2. Banner - 重点还原文字 */
.banner-card {
  margin-top: 60rpx;
  background-color: #eceae5; /* 设计稿米灰色 */
  border-radius: 40rpx;
  height: 300rpx;
  display: flex;
  position: relative;
  overflow: visible !important;
}
.banner-content {
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
}
.brand-title {
  font-size: 56rpx;
  margin-left: 150rpx;
  font-weight: 600;
  color: #7A6418;
  letter-spacing: 4rpx;
}
.brand-en {
  font-family: 'Yellowtail'; /* 使用加载好的外部字体 */
  font-size: 28rpx;
  color: #7A6418;
  margin-top: 10rpx;
  margin-left: 300rpx;
}
.join-btn {
  width: 192rpx;
  height: 58rpx;
  margin-top: 40rpx;
  background-color: #7a6a35;
  color: #ffffff;
  font-size: 24rpx;
  padding: 14rpx 36rpx;
  border-radius: 30rpx;
  align-self: flex-start;
  display: flex;
  justify-content: center;  /* 水平居中 */
  align-items: center;      /* 垂直居中 */
  font-family: 'Semibold';
}
.banner-image-space {
  position: absolute;
  /* 1. 强制底部对齐 */
  bottom: 0; 
  /* 2. 强制右边冲出 (负值越大，冲出越多) */
  right: -10rpx; 
  
  /* 3. 设定一个宽度，让图片按比例缩放 */
  width: 212rpx; 
  height: 360rpx;
  display: flex;
  align-items: flex-end; /* 确保内容向下对齐 */
}

.banner-image-space image {
  width: 100%;
  height: 100%;
  display: block; 
}

/* 3. Categories */
.category-scroll {
  white-space: nowrap;
  margin: 50rpx 0 30rpx;
}
.cat-item {
  display: inline-block;
  font-size: 28rpx;
  color: #999;
  padding: 16rpx 44rpx;
  margin-right: 10rpx;
  border-radius: 999rpx; /* ⭐关键：一直保持圆形 */
  transition: background-color 0.3s ease, color 0.3s ease;
}
.cat-item.active {
  background-color: #7a6a35;
  color: #fff;
  border-radius: 40rpx;
  font-weight: 500;
}
/* 容器层：使用特定前缀避免污染全局 view 样式 */
.ts-notice-wrapper {
  min-height: 100vh;
  background-color: #71602e; /* 还原图中的深褐色 */
  padding: 0 40rpx;
  box-sizing: border-box;
}

/* 导航栏 */
.ts-header-area {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  padding-top: 60rpx;
  position: relative;
}

.ts-icon-back {
  position: absolute;
  left: 10rpx;
  color: #ffffff;
  font-size: 38rpx;
}

.ts-header-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 500;
}

/* 公告卡片：还原图中的半透明细边框 */
.ts-announcement-card {
  margin-top: 30rpx;
  background-color: rgba(255, 255, 255, 0.08); 
  border: 1px solid rgba(255, 255, 255, 0.35); 
  border-radius: 24rpx;
  padding: 30rpx;
  position: relative;
  min-height: 220rpx;
}

/* 左上角小字日期 */
.ts-post-date {
  position: absolute;
  top: 15rpx;
  left: 20rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 居中内容布局 */
.ts-content-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 20rpx;
}

.ts-main-subject {
  color: #ffffff;
  font-size: 30rpx;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

/* 还原图中的中间横线 */
.ts-divider-line {
  width: 80%; 
  height: 1rpx;
  background-color: rgba(255, 255, 255, 0.4);
  margin-bottom: 25rpx;
}

.ts-body-desc {
  color: #ffffff;
  font-size: 26rpx;
  text-align: center;
  line-height: 1.6;
}