/* 页面基础背景 */
page {
  background-color: #ffffff;
  color: #333;
  padding-bottom: 140rpx;
}

/* 顶部 Header */
.header {
  padding: 40rpx 30rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}
.slogan { font-size: 24rpx; color: #8c764b; }
.brand-title { font-size: 44rpx; color: #5d5131; font-weight: 500; }

/* Banner */
.banner-box {
  width: 100%;
  height: 500rpx;
  background-color: #e0e0e0; /* 灰底占位 */
  border-bottom: 2rpx dashed #ccc; /* 模拟设计稿虚线 */
}
.banner-img { width: 100%; height: 100%; }

/* 导航图标区 */
.nav-grid {
  display: flex;
  justify-content: space-around;
  padding: 50rpx 20rpx;
}
.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.icon-wrap {
  width: 110rpx;
  height: 110rpx;
  margin-bottom: 15rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}
.icon-wrap image { width: 100%; }
.nav-text { font-size: 28rpx; font-weight: 500; }
.text-orange { color: #f48e57; }
.text-pink { color: #eb6877; }
.text-green { color: #8ec060; }

/* 经典系列按钮 */
.section-title-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}
.classic-btn {
  background: #f7f3f0; /* 浅米色背景 */
  padding: 18rpx 90rpx;
  border-radius: 60rpx;
  font-size: 32rpx;
  color: #333;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1); /* 阴影 */
  border: 1rpx solid #eee;
}

/* 商品卡片布局 */
.product-list {
  display: flex;
  justify-content: space-between;
  padding: 0 30rpx;
}
.product-card {
  width: 335rpx;
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.08);
  background: #fff;
}
.card-top {
  height: 335rpx;
  background-color: #ddd; /* 图片占位 */
}
.card-bottom {
  height: 80rpx;
  background-color: #fcfaf7; /* 卡片底部浅米色 */
  padding: 10rpx 30rpx;
  display: flex;
  align-items: center;
}
.price-unit { color: #5d5131; font-weight: bold; font-size: 34rpx; }