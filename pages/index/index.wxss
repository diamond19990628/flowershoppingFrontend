/* 全局背景 */
page {
  background-color: #fbfbfb;
  color: #333;
  padding-top: 0;
}
.home-container {
  margin: 0 30rpx 180rpx;
}
/* 4. Goods Grid */
.goods-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.goods-item {
  width: 335rpx;
  background: #EFEFEF;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
}
.goods-image-space {
  width: 100%;
  height: 335rpx;
  background-color: #e0e0e0; /* 纯色块占位 */
}
.goods-image-space image{
  width: 100%;
  height: 100%;
}
.goods-info {
  padding: 24rpx;
}
.goods-name {
  font-size: 28rpx;
  color: #333;
}
.goods-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}
.price-symbol {
  color: #8c764b;
  font-weight: 600;
}
.arrow-icon {
  width: 44rpx;
  height: 44rpx;
  background: #f8f8f8;
  color: #8c764b;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
