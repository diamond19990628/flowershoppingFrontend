/* 全局背景 */
page {
  background-color: #fbfbfb;
  color: #333;
}
.home-container {
  padding: 20rpx 30rpx 180rpx;
}
/* 4. Goods Grid */
.goods-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.goods-item {
  width: 335rpx;
  background: #fff;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
}
.goods-image-space {
  width: 100%;
  height: 335rpx;
  background-color: #e0e0e0; /* 纯色块占位 */
}
.goods-info {
  padding: 24rpx;
}
.goods-name {
  font-size: 28rpx;
  color: #333;
}
.goods-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}
.price-symbol {
  color: #8c764b;
  font-weight: 600;
}
.arrow-icon {
  width: 44rpx;
  height: 44rpx;
  background: #f8f8f8;
  color: #8c764b;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 5. Custom TabBar */
.footer-tabbar {
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
  height: 120rpx;
  background-color: #fff;
  border-radius: 60rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.08);
}
.tab-item {
  font-size: 22rpx;
  color: #ccc;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.tab-item.active {
  color: #7a6a35;
  font-weight: bold;
}
/* 顶部的装饰点 */
.tab-item.active::before {
  content: "•";
  font-size: 30rpx;
  margin-bottom: -10rpx;
}