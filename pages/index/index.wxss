/* 全局背景 */
page {
  background-color: #fbfbfb;
  color: #333;
  padding-top: 0;
}
.home-container {
  margin: 0 30rpx 180rpx;
}
/* 4. Goods Grid */
.goods-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.goods-item {
  width: 335rpx;
  background: #EFEFEF;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
}
.goods-image-space {
  width: 100%;
  height: 335rpx;
  background-color: #e0e0e0; /* 纯色块占位 */
}
.goods-image-space image{
  width: 100%;
  height: 100%;
}
.goods-info {
  padding: 24rpx;
}
.goods-name {
  font-size: 28rpx;
  color: #333;
}
.goods-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}
.price-symbol {
  color: #8c764b;
  font-weight: 600;
}
.arrow-icon {
  width: 44rpx;
  height: 44rpx;
  background: #f8f8f8;
  color: #8c764b;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 9999;
  background: #ffffff;
  display: flex;
  justify-content: center;
  align-items: center;
}
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100vw;
  height: 100vh; 
  overflow: hidden;
  padding-top: 160rpx; 
  box-sizing: border-box;
  position: fixed;
}

/* 文字区块 */
.text-section {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.welcome-cn {
  font-size: 32rpx;
  color: #8c764b;
  letter-spacing: 4rpx;
  margin-bottom: 40rpx;
}

.brand-title {
  font-size: 80rpx; /* 约 40px */
  font-weight: 500;
  color: #5d5131;
  margin-bottom: 60rpx;
  letter-spacing: 6rpx;
}

/* 英文区域 */
.en-group {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.welcome-en {
  margin-left: -200rpx;
  font-size: 44rpx;
  color: #8c764b;
  font-style: italic; /* 模拟手写感 */
  font-family: "Yellowtail"; /* 建议使用衬线字体 */
}

.brand-en {
  font-size: 44rpx;
  color: #5d5131;
  font-style: italic;
  font-family: "Yellowtail", serif;
  margin-left: 100rpx; /* 模拟错落感 */
}

.image-placeholder {
  width: 100%;
  position: absolute;
  bottom: 0;
  left: 0;
}

.image-placeholder image {
  width: 100%;
  display: block;
}